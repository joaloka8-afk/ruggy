TELEGRAM_BOT_TOKEN=replace_me

# Optional: enables richer report narration + chat interaction
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GIPHY_API_KEY=

# Optional: set this to enable webhook mode (recommended on Railway web service)
# Example: https://your-app.up.railway.app
TELEGRAM_WEBHOOK_URL=
WEBHOOK_PATH=/telegram/webhook

# Runtime
PORT=3000
LOG_LEVEL=info

# Chat memory backend:
# - postgres (recommended on Railway with Postgres plugin)
# - file (local fallback)
CHAT_MEMORY_BACKEND=postgres
DATABASE_URL=
CHAT_MEMORY_TURNS=8
CHAT_MEMORY_FILE=.data/chat-memory.json
